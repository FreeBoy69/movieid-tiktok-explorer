# Copy to `.env.local` in this folder (or set variables here) and paste your key.
# Local dev: the Express server loads `.env` and `.env.local`.

# Required - Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_API_KEY_BACKUP=

# Optional but recommended - reliable movie posters from TMDB.
# Use either the v3 API key or the v4 Read Access Token from https://www.themoviedb.org/settings/api
# TMDB_API_KEY=
# TMDB_READ_ACCESS_TOKEN=

# Optional - YouTube Niche Radar mini app.
# Create a YouTube Data API v3 key in Google Cloud and paste it into `.env.local`.
# YOUTUBE_API_KEY=

# Optional - Google sign-in + connected YouTube channel accounts.
# Google Cloud OAuth client must allow:
#   Authorized JavaScript origin: https://autoyt.cc
#   Authorized redirect URI: https://autoyt.cc/api/auth/google/callback
# Scopes requested: openid, email, profile, youtube.readonly, yt-analytics.readonly, youtube.upload.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# AUTH_SECRET=replace-with-a-long-random-string
# APP_URL=https://autoyt.cc

# Required for persistent saved TikTok playlists - local PostgreSQL connection.
# Example: DATABASE_URL=postgres://postgres:your_password@localhost:5432/postgres
# DATABASE_URL=
# Optional if psql.exe is not on the Node server PATH:
# PSQL_PATH=C:\Program Files\PostgreSQL\17\bin\psql.exe

# Optional - Movie ID comment hints from TikTok replies to "movie name?" comments (default on)
# MOVIE_ID_COMMENT_HINTS=true
# MOVIE_ID_COMMENT_HINT_MIN_CONFIDENCE=0.85
# Fallback when no direct "movie name:" reply: infer from comment corpus + TMDB (default 0.72)
# MOVIE_ID_COMMENT_CORPUS_MIN_CONFIDENCE=0.72
# Local headless fetch pushes comments to VPS; server does not scrape comments itself by default
# TIKTOK_COMMENT_SERVER_FETCH=false
# Shared secret for POST /api/tiktok/comments/cache from local_comment_bridge.mjs
# TIKTOK_COMMENT_PUSH_TOKEN=
# LOCAL_COMMENT_BRIDGE_PORT=8765
# TIKTOK_COMMENTS_LIMIT=40
# TIKTOK_COMMENT_REPLY_LIMIT=12
# TIKTOK_COMMENTS_TIMEOUT_MS=120000
# Reuse one Playwright/TikTok-Api session for comment fetches instead of launching per request (default on)
# TIKTOK_COMMENT_DAEMON=true
# TIKTOK_COMMENT_DAEMON_IDLE_MS=1800000
# Cache scraped TikTok comment threads per video id (default 168 hours)
# TIKTOK_COMMENT_CACHE_HOURS=168

# TIKTOK_LIST_MAX=5000

# Optional - TikTok Explorer listings ([TikTok-Api](https://github.com/davidteather/TikTok-Api))
# Session init mirrors tiktok-rewriter/backend/tiktok_api_list.py (create_sessions with
# ms_tokens / num_sessions / sleep_after / browser only). If a channel or playlist returns
# "empty response" the fix is almost always a fresh ms_token:
# TIKTOK_MS_TOKEN=   # paste the ms_token cookie value from tiktok.com (DevTools > Application > Cookies)
# TIKTOK_COOKIE_HEADER=   # optional full Cookie header from tiktok.com for clean playback / download requests
# TIKTOK_COOKIES=   # alias for TIKTOK_COOKIE_HEADER
# TIKTOK_YTDLP_COOKIES_FILE=   # optional Netscape cookies.txt path for yt-dlp fallback
# TIKTOK_ALLOW_WATERMARK_FALLBACK=0   # set to 1 only if watermarked yt-dlp / wmplay fallback is acceptable
# TIKTOK_BROWSER=chromium   # "webkit" sometimes bypasses Chromium blocks
# TIKTOK_SLEEP_AFTER=3   # seconds after session create; raise to 8 if msToken is still being set
# TIKTOK_TIMEOUT_MS=90000   # initial page.goto timeout (TikTok-Api sets the real one too late)
# Full path to python.exe if TikTok listing fails (Windows: py launcher may point at C:\Python312\... that does not exist)
# PYTHON_PATH=C:\Users\You\AppData\Local\Programs\Python\Python312\python.exe

# Optional - used for hosted deployments
# APP_URL=
